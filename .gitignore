# Dependencies
node_modules/
.pnpm-store/

# Env files - never commit secrets
.env
.env.*
!.env.example

# Shell scripts (may contain local secrets/paths) - allowlist explicitly if needed
*.sh

# Next.js
.next/
out/

# Turborepo
.turbo/

# Build outputs
dist/
build/

# Python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/
.pytest_cache/
.ruff_cache/

# Prisma
apps/web/prisma/*.db

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Editor / OS
.DS_Store
.vscode/*
!.vscode/extensions.json
.idea/
.claude/

# Test coverage
coverage/

# Playwright MCP verification artifacts
.playwright-mcp/

# Azure / IaC local artifacts
infra/*.bicepparam.local.json

# Personal editor workspace (machine-specific paths)
*.code-workspace

# Dev-stack logs from scripts/start-dev.sh
.logs/
