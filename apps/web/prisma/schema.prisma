// SpecMate core data model — every other epic builds on this schema.
// Prisma is the source of truth for migrations; apps/api mirrors these tables
// with hand-written SQLAlchemy models (apps/api/app/models.py) kept in sync manually.
//
// Soft-delete: soft-deletable models carry a nullable `deletedAt` — active rows have
// `deletedAt = null`. ReviewDecision and AuditEvent are immutable logs (no deletedAt/updatedAt
// at all); a correction is a new row, not an edit.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  REVIEWER
  VIEWER
}

// Organization-level roles (Issue 12.11): OWNER owns billing/org settings and can
// create/delete Workspaces; ADMIN manages Workspaces and Teams but not billing.
// Both cascade to an effective Workspace ADMIN in every workspace of the org.
enum OrgRole {
  OWNER
  ADMIN
}

// Self-reported company size, collected at signup (Onboarding Flow redesign).
// Nullable on Organization since pre-existing/backfilled orgs have no size data.
enum OrgSize {
  SOLO
  SMALL // 2-10
  MEDIUM // 11-50
  LARGE // 51-200
  ENTERPRISE // 200+
}

// Top of the tenancy hierarchy (Issue 12.10): Organization → Workspace → Team →
// User. One per paying customer company. Introduced additively — Workspace keeps
// its existing semantics (and, for now, its Stripe billing fields from Issue
// 10.9; consolidating billing at the org level is a decision deferred until real
// pricing lands). Existing workspaces were backfilled into implicit
// single-workspace organizations (see migration add_org_team_hierarchy).
model Organization {
  id        String    @id @default(cuid())
  name      String
  size      OrgSize?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  members    OrganizationMember[]
  workspaces Workspace[]
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           OrgRole
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@unique([organizationId, userId])
}

enum SourceKind {
  DOCX
  PDF
  XLSX
  CSV
  TXT
  TRANSCRIPT
  CONFLUENCE
  SLACK
  JIRA_REF
  ADO_REF
  GITHUB_REF
}

enum SourceStatus {
  QUEUED
  PARSING
  PARSED
  FAILED
}

enum ScanStatus {
  PENDING
  CLEAN
  INFECTED
}

enum DraftItemType {
  EPIC
  STORY
  TASK
  SUBTASK
  ACCEPTANCE_CRITERIA
  TEST
  RISK
  NFR
  DEPENDENCY
  ASSUMPTION
  QUESTION
}

enum ReviewDecisionType {
  APPROVED
  REJECTED
  EDITED
}

enum PublishTarget {
  JIRA
  ADO
  GITHUB
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
}

enum PricingTier {
  STARTER
  ENTERPRISE
}

enum SubscriptionStatus {
  NONE // no Stripe subscription yet (e.g. ENTERPRISE, sales-assisted, not self-serve billed)
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

model Workspace {
  id             String    @id @default(cuid())
  name           String
  // Nullable by design (Issue 12.10): all real workspaces have an organization
  // (backfilled implicit single-workspace orgs for pre-hierarchy data; signup
  // always creates one), but the column stays nullable so a workspace with no
  // org is simply "no org-level grants" (deny-by-default) rather than a broken
  // row — and existing test fixtures keep working unchanged.
  organizationId String?
  // Manually-set placeholder for the workspace's subscription revenue, used only to
  // compute an AI cost-to-revenue ratio (Issue #1.6). Superseded by real subscription
  // data (subscriptionBaseUsd) once Stripe billing is live for a workspace (Issue
  // 10.9) — kept as a fallback for ENTERPRISE workspaces billed outside Stripe.
  planRevenueUsd Decimal?  @db.Decimal(10, 2)
  // Duplicate-detection sensitivity (Issue 3.5), 0..1; null -> env default.
  duplicateThreshold Float?
  // 1 = single-reviewer approval (default); 2 = reviewer approval + ADMIN sign-off (Issue 4.7).
  approvalStages Int @default(1)
  // Time-to-first-value instrumentation (Issue 10.10): stamped once, the first time
  // this workspace's first generation run completes. createdAt is the signup moment,
  // so (firstGenerationAt - createdAt) is the workspace's actual time-to-first-value.
  firstGenerationAt DateTime?

  // Pricing & billing (Issue 10.9). STARTER is self-serve, billed via Stripe
  // (subscriptionBaseUsd + metered per-published-item overage — see UsagePeriod).
  // ENTERPRISE is sales-assisted, custom pricing, not necessarily billed through
  // Stripe (falls back to planRevenueUsd for cost-to-revenue tracking).
  pricingTier            PricingTier        @default(STARTER)
  subscriptionStatus     SubscriptionStatus @default(NONE)
  stripeCustomerId       String?            @unique
  stripeSubscriptionId   String?            @unique
  // Real base subscription price once a Stripe subscription is active — read from
  // the Stripe subscription object, not hand-entered like planRevenueUsd.
  subscriptionBaseUsd    Decimal?           @db.Decimal(10, 2)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization              Organization?             @relation(fields: [organizationId], references: [id])
  members                   WorkspaceMember[]
  teams                     Team[]
  projects                  Project[]
  auditEvents               AuditEvent[]
  invites                   WorkspaceInvite[]
  aiCallLogs                AiCallLog[]
  snapshots                 Snapshot[]
  usagePeriods              UsagePeriod[]
  atlassianConnectInstalls  AtlassianConnectInstall[]
  apiRateLimitCounters      ApiRateLimitCounter[]
}

// One row per Jira Cloud site that has installed the SpecMate Atlassian
// Connect app (Issue 10.2) — multi-tenant by design: many customer sites can
// each independently install/uninstall, distinct from the single-tenant
// env-configured CloudTokenConnection used by direct OAuth/API-token auth
// (Issue 5.1). `workspaceId` is nullable because Atlassian POSTs the
// `installed` lifecycle callback *before* any SpecMate workspace is known to
// be associated with it — an admin claims the install (links it to a
// workspace) afterward via a settings page. `clientKey` is the stable
// per-site identifier Atlassian sends on every lifecycle/request callback;
// `sharedSecret` signs/verifies the JWTs both directions (Atlassian -> app on
// incoming requests, app -> Jira on outgoing API calls, "2-Legged JWT").
model AtlassianConnectInstall {
  id            String    @id @default(cuid())
  clientKey     String    @unique
  sharedSecret  String
  baseUrl       String
  displayUrl    String?
  productType   String?
  installedAt   DateTime  @default(now())
  uninstalledAt DateTime?
  workspaceId   String?
  claimedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id])
}

// One row per workspace per billing period (calendar month, UTC) — the metered
// usage component of Issue 10.9's hybrid pricing (base subscription + per-item
// overage). `publishedItemCount` is computed by counting PublishedItem rows
// created in [periodStart, periodEnd); `reportedToStripeAt` is set once that
// count has been pushed to Stripe as a usage record (idempotent — never
// double-reported for the same period).
model UsagePeriod {
  id                 String    @id @default(cuid())
  workspaceId        String
  periodStart        DateTime
  periodEnd          DateTime
  publishedItemCount Int       @default(0)
  // How much of publishedItemCount has been pushed to Stripe so far — meter
  // events are additive, so only the delta since the last report is ever sent.
  reportedCount      Int       @default(0)
  reportedToStripeAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, periodStart])
}

model ApiRateLimitCounter {
  workspaceId  String
  windowStart  DateTime
  requestCount Int      @default(0)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@id([workspaceId, windowStart])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships      WorkspaceMember[]
  orgMemberships   OrganizationMember[]
  teamMemberships  TeamMember[]
  reviewDecisions  ReviewDecision[]
  auditEvents      AuditEvent[]
  sentInvites      WorkspaceInvite[]
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        Role
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([workspaceId, userId])
}

// Team (Issue 12.10/12.11): a grouping of users within a Workspace, used for
// permission scoping. Semantics — team scoping is a *restriction*, not a grant:
// workspace membership grants access as before, but a non-admin member who
// belongs to at least one project-scoped team (a team with TeamProject rows)
// has their visibility narrowed to the union of their scoped teams' projects.
// Teams with no TeamProject rows are plain groupings and never restrict.
// Workspace ADMINs and org-level OWNER/ADMINs are never restricted by team
// scope (they need whole-workspace visibility to administer it).
model Team {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace Workspace     @relation(fields: [workspaceId], references: [id])
  members   TeamMember[]
  projects  TeamProject[]

  @@unique([workspaceId, name])
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
}

model TeamProject {
  id        String   @id @default(cuid())
  teamId    String
  projectId String
  createdAt DateTime @default(now())

  team    Team    @relation(fields: [teamId], references: [id])
  project Project @relation(fields: [projectId], references: [id])

  @@unique([teamId, projectId])
}

model Project {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace      Workspace       @relation(fields: [workspaceId], references: [id])
  sources        Source[]
  draftItems     DraftItem[]
  aiCallLogs     AiCallLog[]
  referenceItems  ReferenceItem[]
  generationRuns  GenerationRun[]
  publishMappings PublishMapping[]
  snapshots       Snapshot[]
  teamScopes      TeamProject[]
}

model Source {
  id         String       @id @default(cuid())
  projectId  String
  name       String
  kind       SourceKind
  status     SourceStatus @default(QUEUED)
  storageKey String?
  sizeBytes  Int?
  mimeType   String?
  // External identity for connector-sourced content (Confluence page ID, Slack channel
  // ID) — re-syncing upserts by (projectId, externalRef) instead of duplicating Sources.
  externalRef String?
  // Last parse failure message (human-readable, from the typed parser errors) — shown
  // in the source management UI so failures are actionable. Cleared on successful parse.
  parseError String?
  // Always PENDING -> CLEAN today (see apps/web/src/lib/upload-validation.ts#scanFile) — no real
  // AV integration exists yet. INFECTED is modeled now so the schema doesn't need a follow-up
  // migration once a real scanner is wired up.
  scanStatus ScanStatus   @default(PENDING)
  // Versioning (Issue 9.1): re-uploading over an existing Source creates a NEW Source
  // row chained via previousVersionId, rather than overwriting — the prior version's
  // Source + RawRequirements stay queryable/untouched. version=1 for originals.
  version           Int     @default(1)
  previousVersionId String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  deletedAt  DateTime?

  project          Project           @relation(fields: [projectId], references: [id])
  rawRequirements  RawRequirement[]
  traceLinks       TraceLink[]
  previousVersion  Source?           @relation("SourceVersionChain", fields: [previousVersionId], references: [id])
  nextVersions     Source[]          @relation("SourceVersionChain")
  diffs            SourceDiff[]

  @@unique([projectId, externalRef])
}

// One row per new-version ingestion (Issue 9.1): the computed diff of this Source's
// RawRequirements against its previousVersion's, at the fragment level. Read by
// targeted regeneration (Issue 9.2) to scope which fragments actually changed.
model SourceDiff {
  id              String   @id @default(cuid())
  sourceId        String
  previousSourceId String
  addedCount      Int
  removedCount    Int
  modifiedCount   Int
  unchangedCount  Int
  // [{changeType: added|removed|modified|unchanged, rawRequirementId, previousRawRequirementId, sectionPath}]
  fragments Json
  createdAt DateTime @default(now())

  source Source @relation(fields: [sourceId], references: [id])

  @@unique([sourceId])
}

model RawRequirement {
  id          String    @id @default(cuid())
  sourceId    String
  text        String
  sectionPath String
  order       Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  source     Source      @relation(fields: [sourceId], references: [id])
  traceLinks TraceLink[]
}

enum DraftItemStatus {
  PENDING
  APPROVED
  REJECTED
  EDITED
}

model DraftItem {
  id           String          @id @default(cuid())
  projectId    String
  type         DraftItemType
  title        String
  description  String
  payload      Json?
  qualityScore Int?
  parentId     String?
  // Review state (Epic 4). APPROVED locks further regeneration unless reopened.
  status       DraftItemStatus @default(PENDING)
  // Two-stage approval (Issue 4.7): set when an ADMIN signs off after approval.
  // Only consulted when Workspace.approvalStages == 2.
  signedOffByUserId String?
  // Generation metadata (Epic 3)
  promptVersion   String?
  generationRunId String?
  // {completeness, clarity, testability, specificity, rationale} — Issue 3.4
  scoreDetail Json?
  // {duplicate: {key, confidence, tool}, gap: {question}, noTrace: bool} — Issues 3.5/3.6/3.3
  flags Json?
  // Immutable first AI draft {title, description, payload} — never overwritten (Issue 4.3)
  originalDraft Json?
  // Sequence of field-level diffs [{at, actorUserId, field, before, after}] (Issue 4.3)
  editHistory Json?
  // Revision chain for regeneration (Issue 3.9): this item supersedes revisionOfId
  revisionOfId String?
  // Set only by targeted regeneration (Issue 9.2) to the triggering new-version Source —
  // the delta review queue (Issue 9.3) filters on this to show just this run's changes.
  sourceVersionId String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  project         Project          @relation(fields: [projectId], references: [id])
  parent          DraftItem?       @relation("DraftItemHierarchy", fields: [parentId], references: [id])
  children        DraftItem[]      @relation("DraftItemHierarchy")
  reviewDecisions ReviewDecision[]
  publishedItems  PublishedItem[]
  traceLinks      TraceLink[]
}

model ReviewDecision {
  id           String              @id @default(cuid())
  draftItemId  String
  decision     ReviewDecisionType
  actorUserId  String
  notes        String?
  createdAt    DateTime            @default(now())

  draftItem DraftItem @relation(fields: [draftItemId], references: [id])
  actor     User      @relation(fields: [actorUserId], references: [id])
}

model PublishedItem {
  id          String        @id @default(cuid())
  draftItemId String
  targetTool  PublishTarget
  externalKey String
  externalUrl String
  // Snapshot of {title, description, status} as SpecMate last wrote/read it —
  // the baseline drift detection (Issue 9.5) diffs the live remote state against.
  // Set on every create/update publish and refreshed on every drift check.
  lastKnownState Json?
  lastSyncedAt   DateTime?
  createdAt   DateTime      @default(now())
  deletedAt   DateTime?

  draftItem  DraftItem    @relation(fields: [draftItemId], references: [id])
  traceLinks TraceLink[]
  driftFlags DriftFlag[]
}

// One row per detected drift (Issue 9.5): an external issue changed outside
// SpecMate since the last publish/sync. Resolved explicitly by a reviewer —
// SpecMate never silently overwrites the external change on its next update.
enum DriftResolution {
  ACCEPT_EXTERNAL
  REASSERT_SPECMATE
}

model DriftFlag {
  id              String           @id @default(cuid())
  publishedItemId String
  // What changed, e.g. {title: {before, after}, description: {before, after}, status: {before, after}}
  diff            Json
  detectedAt      DateTime         @default(now())
  resolution      DriftResolution?
  resolvedAt      DateTime?
  resolvedByUserId String?

  publishedItem PublishedItem @relation(fields: [publishedItemId], references: [id])
}

enum AuditActorType {
  USER
  SYSTEM
  AI
}

// Append-only: a DB trigger (see migration add_audit_immutability_and_snapshots)
// rejects UPDATE/DELETE unless the maintenance GUC is set — no application path
// may mutate an existing event (Issue 8.1).
model AuditEvent {
  id          String         @id @default(cuid())
  workspaceId String
  projectId   String?
  actorUserId String?
  actorType   AuditActorType @default(USER)
  action      String
  entityType  String
  entityId    String
  beforeState Json?
  afterState  Json?
  metadata    Json?
  createdAt   DateTime       @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  actor     User?     @relation(fields: [actorUserId], references: [id])

  @@index([workspaceId, projectId, createdAt])
}

// Point-in-time export of a project's full trace map (Issue 8.4). Immutable once
// generated — the stored JSON is the artifact; PDF renders read from `data`, never
// from live tables, so the snapshot stays valid if underlying data later changes.
// No updatedAt/deletedAt (same append-only convention as AuditEvent); a DB trigger
// rejects UPDATE.
model Snapshot {
  id              String   @id @default(cuid())
  workspaceId     String
  projectId       String
  createdByUserId String?
  kind            String   @default("TRACE_MAP")
  data            Json
  createdAt       DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  project   Project   @relation(fields: [projectId], references: [id])
}

// Immutable log of every AI adapter call — no deletedAt/updatedAt, same convention
// as ReviewDecision/AuditEvent. Populated by apps/api's app.services.ai; aggregated
// by the (future) Issue #1.6 per-customer cost-tracking dashboard.
model AiCallLog {
  id                  String   @id @default(cuid())
  workspaceId         String
  projectId           String
  task                String
  model               String
  promptVersion       String?
  inputTokens         Int
  outputTokens        Int
  cacheReadTokens     Int
  cacheCreationTokens Int
  costUsd             Decimal  @db.Decimal(12, 6)
  latencyMs           Int
  createdAt           DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  project   Project   @relation(fields: [projectId], references: [id])
}

// Pending workspace invitation, resolved via a shareable token link (no email delivery yet).
model WorkspaceInvite {
  id              String       @id @default(cuid())
  workspaceId     String
  email           String
  role            Role
  token           String       @unique
  status          InviteStatus @default(PENDING)
  invitedByUserId String
  expiresAt       DateTime
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  workspace  Workspace @relation(fields: [workspaceId], references: [id])
  invitedBy  User      @relation(fields: [invitedByUserId], references: [id])
}

// Join record proving full traceability: Source -> RawRequirement -> DraftItem -> PublishedItem.
// publishedItemId is nullable because a trace exists before a DraftItem is published.
// One AI generation run over a project's RawRequirements (Issue 3.1). contentHash is
// a sha256 of the ordered raw-requirement texts — re-running against unchanged content
// reuses the run instead of duplicating items (idempotency), and stats power Issue 3.10.
model GenerationRun {
  id            String   @id @default(cuid())
  projectId     String
  contentHash   String
  promptVersion String
  stats         Json?
  createdAt     DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])

  @@unique([projectId, contentHash])
}

// Per-project publish configuration for a target tool (Epic 5: Jira first).
// Stores the SpecMate->Jira type map, fixed defaults for required Jira fields with
// no natural SpecMate value, and a refreshable snapshot of the discovered Jira
// project metadata (issue types + fields) so publishing doesn't re-query Jira.
enum TicketFormatMode {
  HUMAN
  CODING_AGENT
  BOTH // accepted, not yet supported by publish — see format_adapter.py
}

model PublishMapping {
  id             String            @id @default(cuid())
  projectId      String
  tool           PublishTarget
  remoteProject  String // Jira project key / ADO project name / GitHub "owner/repo"
  typeMap        Json // {EPIC: "Epic", STORY: "Story", ...}
  fieldDefaults  Json? // {customfield_10020: "Backend", ...} fixed values for required fields
  metadata       Json? // discovery snapshot {issueTypes: [...], fetchedAt}
  formatMode     TicketFormatMode  @default(HUMAN)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  project Project @relation(fields: [projectId], references: [id])

  @@unique([projectId, tool])
}

// Read-only snapshot of an existing backlog item pulled from Jira/ADO/GitHub (Issues
// #14-16) — reference data for duplicate detection (Issue 3.5), never edited or
// published by SpecMate. Re-sync upserts by (projectId, tool, externalKey). Reuses the
// PublishTarget enum since ingest and publish target the same three tools.
model ReferenceItem {
  id          String        @id @default(cuid())
  projectId   String
  tool        PublishTarget
  externalKey String
  title       String
  description String
  itemType    String
  state       String
  url         String?
  syncedAt    DateTime
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  project Project @relation(fields: [projectId], references: [id])

  @@unique([projectId, tool, externalKey])
}

model TraceLink {
  id               String   @id @default(cuid())
  sourceId         String
  rawRequirementId String
  draftItemId      String
  publishedItemId  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  source         Source          @relation(fields: [sourceId], references: [id])
  rawRequirement RawRequirement  @relation(fields: [rawRequirementId], references: [id])
  draftItem      DraftItem       @relation(fields: [draftItemId], references: [id])
  publishedItem  PublishedItem?  @relation(fields: [publishedItemId], references: [id])
}
