// SpecMate core data model — every other epic builds on this schema.
// Prisma is the source of truth for migrations; apps/api mirrors these tables
// with hand-written SQLAlchemy models (apps/api/app/models.py) kept in sync manually.
//
// Soft-delete: soft-deletable models carry a nullable `deletedAt` — active rows have
// `deletedAt = null`. ReviewDecision and AuditEvent are immutable logs (no deletedAt/updatedAt
// at all); a correction is a new row, not an edit.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  REVIEWER
  VIEWER
}

enum SourceKind {
  DOCX
  PDF
  XLSX
  CSV
  TXT
  TRANSCRIPT
  CONFLUENCE
  SLACK
  JIRA_REF
  ADO_REF
  GITHUB_REF
}

enum SourceStatus {
  QUEUED
  PARSING
  PARSED
  FAILED
}

enum ScanStatus {
  PENDING
  CLEAN
  INFECTED
}

enum DraftItemType {
  EPIC
  STORY
  TASK
  SUBTASK
  ACCEPTANCE_CRITERIA
  TEST
  RISK
  NFR
  DEPENDENCY
  ASSUMPTION
  QUESTION
}

enum ReviewDecisionType {
  APPROVED
  REJECTED
  EDITED
}

enum PublishTarget {
  JIRA
  ADO
  GITHUB
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
}

model Workspace {
  id             String    @id @default(cuid())
  name           String
  // Manually-set placeholder for the workspace's subscription revenue, used only to
  // compute an AI cost-to-revenue ratio (Issue #1.6). No real billing system yet —
  // set directly in the DB, no self-serve UI.
  planRevenueUsd Decimal?  @db.Decimal(10, 2)
  // Duplicate-detection sensitivity (Issue 3.5), 0..1; null -> env default.
  duplicateThreshold Float?
  // 1 = single-reviewer approval (default); 2 = reviewer approval + ADMIN sign-off (Issue 4.7).
  approvalStages Int @default(1)
  // Time-to-first-value instrumentation (Issue 10.10): stamped once, the first time
  // this workspace's first generation run completes. createdAt is the signup moment,
  // so (firstGenerationAt - createdAt) is the workspace's actual time-to-first-value.
  firstGenerationAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  members     WorkspaceMember[]
  projects    Project[]
  auditEvents AuditEvent[]
  invites     WorkspaceInvite[]
  aiCallLogs  AiCallLog[]
  snapshots   Snapshot[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships      WorkspaceMember[]
  reviewDecisions  ReviewDecision[]
  auditEvents      AuditEvent[]
  sentInvites      WorkspaceInvite[]
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        Role
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([workspaceId, userId])
}

model Project {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace      Workspace       @relation(fields: [workspaceId], references: [id])
  sources        Source[]
  draftItems     DraftItem[]
  aiCallLogs     AiCallLog[]
  referenceItems  ReferenceItem[]
  generationRuns  GenerationRun[]
  publishMappings PublishMapping[]
  snapshots       Snapshot[]
}

model Source {
  id         String       @id @default(cuid())
  projectId  String
  name       String
  kind       SourceKind
  status     SourceStatus @default(QUEUED)
  storageKey String?
  sizeBytes  Int?
  mimeType   String?
  // External identity for connector-sourced content (Confluence page ID, Slack channel
  // ID) — re-syncing upserts by (projectId, externalRef) instead of duplicating Sources.
  externalRef String?
  // Last parse failure message (human-readable, from the typed parser errors) — shown
  // in the source management UI so failures are actionable. Cleared on successful parse.
  parseError String?
  // Always PENDING -> CLEAN today (see apps/web/src/lib/upload-validation.ts#scanFile) — no real
  // AV integration exists yet. INFECTED is modeled now so the schema doesn't need a follow-up
  // migration once a real scanner is wired up.
  scanStatus ScanStatus   @default(PENDING)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  deletedAt  DateTime?

  project          Project           @relation(fields: [projectId], references: [id])
  rawRequirements  RawRequirement[]
  traceLinks       TraceLink[]

  @@unique([projectId, externalRef])
}

model RawRequirement {
  id          String    @id @default(cuid())
  sourceId    String
  text        String
  sectionPath String
  order       Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  source     Source      @relation(fields: [sourceId], references: [id])
  traceLinks TraceLink[]
}

enum DraftItemStatus {
  PENDING
  APPROVED
  REJECTED
  EDITED
}

model DraftItem {
  id           String          @id @default(cuid())
  projectId    String
  type         DraftItemType
  title        String
  description  String
  payload      Json?
  qualityScore Int?
  parentId     String?
  // Review state (Epic 4). APPROVED locks further regeneration unless reopened.
  status       DraftItemStatus @default(PENDING)
  // Two-stage approval (Issue 4.7): set when an ADMIN signs off after approval.
  // Only consulted when Workspace.approvalStages == 2.
  signedOffByUserId String?
  // Generation metadata (Epic 3)
  promptVersion   String?
  generationRunId String?
  // {completeness, clarity, testability, specificity, rationale} — Issue 3.4
  scoreDetail Json?
  // {duplicate: {key, confidence, tool}, gap: {question}, noTrace: bool} — Issues 3.5/3.6/3.3
  flags Json?
  // Immutable first AI draft {title, description, payload} — never overwritten (Issue 4.3)
  originalDraft Json?
  // Sequence of field-level diffs [{at, actorUserId, field, before, after}] (Issue 4.3)
  editHistory Json?
  // Revision chain for regeneration (Issue 3.9): this item supersedes revisionOfId
  revisionOfId String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  project         Project          @relation(fields: [projectId], references: [id])
  parent          DraftItem?       @relation("DraftItemHierarchy", fields: [parentId], references: [id])
  children        DraftItem[]      @relation("DraftItemHierarchy")
  reviewDecisions ReviewDecision[]
  publishedItems  PublishedItem[]
  traceLinks      TraceLink[]
}

model ReviewDecision {
  id           String              @id @default(cuid())
  draftItemId  String
  decision     ReviewDecisionType
  actorUserId  String
  notes        String?
  createdAt    DateTime            @default(now())

  draftItem DraftItem @relation(fields: [draftItemId], references: [id])
  actor     User      @relation(fields: [actorUserId], references: [id])
}

model PublishedItem {
  id          String        @id @default(cuid())
  draftItemId String
  targetTool  PublishTarget
  externalKey String
  externalUrl String
  createdAt   DateTime      @default(now())
  deletedAt   DateTime?

  draftItem  DraftItem   @relation(fields: [draftItemId], references: [id])
  traceLinks TraceLink[]
}

enum AuditActorType {
  USER
  SYSTEM
  AI
}

// Append-only: a DB trigger (see migration add_audit_immutability_and_snapshots)
// rejects UPDATE/DELETE unless the maintenance GUC is set — no application path
// may mutate an existing event (Issue 8.1).
model AuditEvent {
  id          String         @id @default(cuid())
  workspaceId String
  projectId   String?
  actorUserId String?
  actorType   AuditActorType @default(USER)
  action      String
  entityType  String
  entityId    String
  beforeState Json?
  afterState  Json?
  metadata    Json?
  createdAt   DateTime       @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  actor     User?     @relation(fields: [actorUserId], references: [id])

  @@index([workspaceId, projectId, createdAt])
}

// Point-in-time export of a project's full trace map (Issue 8.4). Immutable once
// generated — the stored JSON is the artifact; PDF renders read from `data`, never
// from live tables, so the snapshot stays valid if underlying data later changes.
// No updatedAt/deletedAt (same append-only convention as AuditEvent); a DB trigger
// rejects UPDATE.
model Snapshot {
  id              String   @id @default(cuid())
  workspaceId     String
  projectId       String
  createdByUserId String?
  kind            String   @default("TRACE_MAP")
  data            Json
  createdAt       DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  project   Project   @relation(fields: [projectId], references: [id])
}

// Immutable log of every AI adapter call — no deletedAt/updatedAt, same convention
// as ReviewDecision/AuditEvent. Populated by apps/api's app.services.ai; aggregated
// by the (future) Issue #1.6 per-customer cost-tracking dashboard.
model AiCallLog {
  id                  String   @id @default(cuid())
  workspaceId         String
  projectId           String
  task                String
  model               String
  promptVersion       String?
  inputTokens         Int
  outputTokens        Int
  cacheReadTokens     Int
  cacheCreationTokens Int
  costUsd             Decimal  @db.Decimal(12, 6)
  latencyMs           Int
  createdAt           DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  project   Project   @relation(fields: [projectId], references: [id])
}

// Pending workspace invitation, resolved via a shareable token link (no email delivery yet).
model WorkspaceInvite {
  id              String       @id @default(cuid())
  workspaceId     String
  email           String
  role            Role
  token           String       @unique
  status          InviteStatus @default(PENDING)
  invitedByUserId String
  expiresAt       DateTime
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  workspace  Workspace @relation(fields: [workspaceId], references: [id])
  invitedBy  User      @relation(fields: [invitedByUserId], references: [id])
}

// Join record proving full traceability: Source -> RawRequirement -> DraftItem -> PublishedItem.
// publishedItemId is nullable because a trace exists before a DraftItem is published.
// One AI generation run over a project's RawRequirements (Issue 3.1). contentHash is
// a sha256 of the ordered raw-requirement texts — re-running against unchanged content
// reuses the run instead of duplicating items (idempotency), and stats power Issue 3.10.
model GenerationRun {
  id            String   @id @default(cuid())
  projectId     String
  contentHash   String
  promptVersion String
  stats         Json?
  createdAt     DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])

  @@unique([projectId, contentHash])
}

// Per-project publish configuration for a target tool (Epic 5: Jira first).
// Stores the SpecMate->Jira type map, fixed defaults for required Jira fields with
// no natural SpecMate value, and a refreshable snapshot of the discovered Jira
// project metadata (issue types + fields) so publishing doesn't re-query Jira.
enum TicketFormatMode {
  HUMAN
  CODING_AGENT
  BOTH // accepted, not yet supported by publish — see format_adapter.py
}

model PublishMapping {
  id             String            @id @default(cuid())
  projectId      String
  tool           PublishTarget
  remoteProject  String // Jira project key / ADO project name / GitHub "owner/repo"
  typeMap        Json // {EPIC: "Epic", STORY: "Story", ...}
  fieldDefaults  Json? // {customfield_10020: "Backend", ...} fixed values for required fields
  metadata       Json? // discovery snapshot {issueTypes: [...], fetchedAt}
  formatMode     TicketFormatMode  @default(HUMAN)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  project Project @relation(fields: [projectId], references: [id])

  @@unique([projectId, tool])
}

// Read-only snapshot of an existing backlog item pulled from Jira/ADO/GitHub (Issues
// #14-16) — reference data for duplicate detection (Issue 3.5), never edited or
// published by SpecMate. Re-sync upserts by (projectId, tool, externalKey). Reuses the
// PublishTarget enum since ingest and publish target the same three tools.
model ReferenceItem {
  id          String        @id @default(cuid())
  projectId   String
  tool        PublishTarget
  externalKey String
  title       String
  description String
  itemType    String
  state       String
  url         String?
  syncedAt    DateTime
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  project Project @relation(fields: [projectId], references: [id])

  @@unique([projectId, tool, externalKey])
}

model TraceLink {
  id               String   @id @default(cuid())
  sourceId         String
  rawRequirementId String
  draftItemId      String
  publishedItemId  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  source         Source          @relation(fields: [sourceId], references: [id])
  rawRequirement RawRequirement  @relation(fields: [rawRequirementId], references: [id])
  draftItem      DraftItem       @relation(fields: [draftItemId], references: [id])
  publishedItem  PublishedItem?  @relation(fields: [publishedItemId], references: [id])
}
