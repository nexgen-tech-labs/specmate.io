# Copy to .env and fill in local values. Never commit .env.

# Postgres connection string (local dev: docker-run Postgres, or Azure Postgres Flexible Server for staging)
# Uses 5434 locally by default to avoid clashing with other projects' Postgres on 5432 — adjust to match your docker run command.
DATABASE_URL="postgresql://postgres:postgres@localhost:5434/specmate?schema=public"

# Auth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Base URL of the FastAPI backend (apps/api)
API_BASE_URL="http://localhost:8000"
