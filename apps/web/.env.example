# Copy to .env and fill in local values. Never commit .env.

# Postgres connection string (local dev: docker-run Postgres, or Azure Postgres Flexible Server for staging)
# Uses 5434 locally by default to avoid clashing with other projects' Postgres on 5432 — adjust to match your docker run command.
DATABASE_URL="postgresql://postgres:postgres@localhost:5434/specmate?schema=public"

# Auth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Base URL of the FastAPI backend (apps/api)
API_BASE_URL="http://localhost:8000"

# Comma-separated emails allowed to view /internal/* pages (e.g. the AI cost dashboard).
# No self-serve UI — edit directly here / in Container App settings.
INTERNAL_ADMIN_EMAILS=""

# Fraction of a workspace's planRevenueUsd that AI cost can reach before the internal
# dashboard flags it as a breach. Defaults to 0.5 (50%) if unset.
AI_COST_ALERT_THRESHOLD_RATIO="0.5"

# Azure Blob Storage for uploaded Source files (Issue #7).
# Local dev: point this at the Azurite emulator's well-known dev connection string —
# see README.md in this directory for the docker run command.
AZURE_STORAGE_CONNECTION_STRING=""
AZURE_STORAGE_CONTAINER="sources"

# Max upload size in MB, enforced both client- and server-side. Defaults to 25 if unset.
MAX_UPLOAD_MB="25"
