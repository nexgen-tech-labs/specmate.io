# Copy to .env and fill in local values. Never commit .env.

# Same Postgres instance used by apps/web (asyncpg driver)
# Uses 5434 locally by default to avoid clashing with other projects' Postgres on 5432 — adjust to match your docker run command.
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5434/specmate"

# Claude API key (Anthropic) — used by the AI pipeline (Issue #4)
ANTHROPIC_API_KEY="sk-ant-..."

ENVIRONMENT="local"
