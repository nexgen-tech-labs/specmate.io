# Copy to .env and fill in local values. Never commit .env.

# Same Postgres instance used by apps/web (asyncpg driver)
# Uses 5434 locally by default to avoid clashing with other projects' Postgres on 5432 — adjust to match your docker run command.
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5434/specmate"

# Claude API key (Anthropic) — used by the AI pipeline (Issue #4)
ANTHROPIC_API_KEY="sk-ant-..."

ENVIRONMENT="local"

# Azure Blob Storage — reads uploaded Source files for parsing (Issue #8).
# Same account apps/web writes to; local dev uses the Azurite emulator (see infra/README.md).
AZURE_STORAGE_CONNECTION_STRING=""
AZURE_STORAGE_CONTAINER="sources"

# Connector credentials (Issues #12-16) — single-tenant, ops-configured for now.
# Atlassian (shared by Jira + Confluence connectors): https://id.atlassian.com/manage-profile/security/api-tokens
ATLASSIAN_EMAIL=""
ATLASSIAN_API_TOKEN=""
JIRA_BASE_URL=""
CONFLUENCE_BASE_URL=""
# Azure DevOps PAT with Work Items (Read) scope
ADO_ORG_URL=""
ADO_PAT=""
# GitHub token with repo read scope
GITHUB_TOKEN=""
# Slack bot token (xoxb-...) with channels:history scope
SLACK_BOT_TOKEN=""

# Default duplicate-detection similarity threshold, 0..1 (Issue 3.5). A workspace's
# duplicateThreshold column overrides this. Defaults to 0.55 if unset.
DUPLICATE_SIMILARITY_THRESHOLD="0.55"
